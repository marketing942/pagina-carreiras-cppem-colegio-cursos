# ==============================================================
# CPPEM Carreiras — Variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com seus dados
# ==============================================================

# URL do seu projeto Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave pública (anon) do Supabase — segura para uso no client
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# (Opcional) Chave service_role — USAR APENAS NO SERVER-SIDE.
# Não é necessária para o funcionamento padrão deste projeto.
# Nunca exponha esta chave no client.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
